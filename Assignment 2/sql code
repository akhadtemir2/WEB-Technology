CREATE SCHEMA IF NOT EXISTS theater;
SET search_path TO theater;

CREATE TABLE IF NOT EXISTS theater.Genres (
    genre_id SERIAL PRIMARY KEY,
    name VARCHAR(30) NOT NULL
);

CREATE TABLE IF NOT EXISTS theater.Theaters (
    theater_id SERIAL PRIMARY KEY,
    name VARCHAR(50) NOT NULL UNIQUE,
    address VARCHAR(100) NOT NULL,
    rating DECIMAL(3,1) CHECK (rating >= 0)
);

CREATE TABLE IF NOT EXISTS theater.Operations (
    operation_id SERIAL PRIMARY KEY,
    operation_type VARCHAR(10) NOT NULL CHECK (operation_type IN ('Purchased', 'Refund', 'Failure'))
);

CREATE TABLE IF NOT EXISTS theater.Customers (
    customer_id SERIAL PRIMARY KEY,
    name VARCHAR(50) NOT NULL,
    age INT NOT NULL CHECK (age >= 0),
    phone_number VARCHAR(15) NOT NULL,
    credit_card VARCHAR(16),
    notes TEXT
);

CREATE TABLE IF NOT EXISTS theater.Seats (
    seat_id SERIAL PRIMARY KEY,
    hall_row INT NOT NULL CHECK (hall_row > 0),
    number INT NOT NULL CHECK (number > 0),
    type_of_seat VARCHAR(22) NOT NULL CHECK (type_of_seat IN ('Normal', 'Comfort', 'VIP'))
);

CREATE TABLE IF NOT EXISTS theater.Films (
    film_id SERIAL PRIMARY KEY,
    name VARCHAR(100) NOT NULL,
    duration TIME NOT NULL,
    genre_id INT NOT NULL,
    release_date DATE NOT NULL CHECK (release_date > '2026-01-01'), 
    age_restriction VARCHAR(3) NOT NULL CHECK (age_restriction IN ('0+', '6+', '12+', '16+', '18+')),
    rating DECIMAL(3,1) DEFAULT 0.0 CHECK (rating >= 0),
    description TEXT NOT NULL,
    FOREIGN KEY (genre_id) REFERENCES theater.Genres(genre_id)
);

CREATE TABLE IF NOT EXISTS theater.Staff (
    staff_id SERIAL PRIMARY KEY,
    name VARCHAR(50) NOT NULL,
    phone VARCHAR(12) NOT NULL,
    age INT NOT NULL CHECK (age >= 18),
    job VARCHAR(20) NOT NULL,
    salary INT NOT NULL CHECK (salary >= 0),
    annual_salary INT GENERATED ALWAYS AS (salary * 12) STORED, 
    theater_id INT NOT NULL,
    FOREIGN KEY (theater_id) REFERENCES theater.Theaters(theater_id)
);

CREATE TABLE IF NOT EXISTS theater.Showtime (
    showtime_id SERIAL PRIMARY KEY,
    film_id INT NOT NULL,
    theater_id INT NOT NULL,
    hall_number INT NOT NULL,
    date DATE NOT NULL CHECK (date > '2026-01-01'),
    start_time TIME NOT NULL,
    status VARCHAR(20) DEFAULT 'Scheduled',
    FOREIGN KEY (film_id) REFERENCES theater.Films(film_id),
    FOREIGN KEY (theater_id) REFERENCES theater.Theaters(theater_id)
);

CREATE TABLE IF NOT EXISTS theater.Pricing (
    pricing_id SERIAL PRIMARY KEY,
    type_of_seat VARCHAR(22) NOT NULL,
    adult_price DECIMAL(6,2) NOT NULL CHECK (adult_price >= 0),
    child_price DECIMAL(6,2) NOT NULL CHECK (child_price >= 0),
    theater_id INT NOT NULL,
    FOREIGN KEY (theater_id) REFERENCES theater.Theaters(theater_id)
);

CREATE TABLE IF NOT EXISTS theater.Reservations (
    reservation_id SERIAL PRIMARY KEY,
    customer_id INT NOT NULL,
    showtime_id INT NOT NULL,
    time TIME NOT NULL,
    status VARCHAR(10) NOT NULL CHECK (status IN ('Pending', 'Confirmed', 'Cancelled')),
    operation_id INT,
    FOREIGN KEY (customer_id) REFERENCES theater.Customers(customer_id),
    FOREIGN KEY (showtime_id) REFERENCES theater.Showtime(showtime_id),
    FOREIGN KEY (operation_id) REFERENCES theater.Operations(operation_id)
);

CREATE TABLE IF NOT EXISTS theater.Reservation_Seats (
    reservation_id INT NOT NULL,
    seat_id INT NOT NULL,
    PRIMARY KEY (reservation_id, seat_id),
    FOREIGN KEY (reservation_id) REFERENCES theater.Reservations(reservation_id),
    FOREIGN KEY (seat_id) REFERENCES theater.Seats(seat_id)
);

ALTER TABLE theater.Genres ADD CONSTRAINT uq_genre_name UNIQUE (name);
ALTER TABLE theater.Staff ALTER COLUMN phone TYPE VARCHAR(20);
ALTER TABLE theater.Customers DROP COLUMN notes;
ALTER TABLE theater.Customers ADD COLUMN email VARCHAR(100);
ALTER TABLE theater.Customers ADD CONSTRAINT uq_customer_email UNIQUE (email);

TRUNCATE TABLE theater.Genres, theater.Theaters, theater.Operations, theater.Customers, 
theater.Seats, theater.Films, theater.Staff, theater.Showtime, theater.Pricing, 
theater.Reservations, theater.Reservation_Seats CASCADE;

