CREATE TABLE IF NOT EXISTS Genres (
    genre_id SERIAL PRIMARY KEY,
    name     VARCHAR(30) NOT NULL
);

CREATE TABLE IF NOT EXISTS Films (
    film_id         SERIAL PRIMARY KEY,
    name            VARCHAR(20) NOT NULL,
    duration        TIME NOT NULL,
    genre_id        INT NOT NULL,
    release_date    DATE NOT NULL,
    age_restriction VARCHAR(3) NOT NULL,
    rating          DECIMAL(2,1) DEFAULT 0 NOT NULL,
    description     TEXT NOT NULL,
    FOREIGN KEY (genre_id) REFERENCES Genres(genre_id)
);

CREATE TABLE IF NOT EXISTS Theaters (
    theater_id SERIAL PRIMARY KEY,
    name       VARCHAR(20) NOT NULL,
    address    VARCHAR(30) NOT NULL,
    rating     DECIMAL(2,1)
);

CREATE TABLE IF NOT EXISTS Staff (
    staff_id   SERIAL PRIMARY KEY,
    name       VARCHAR(20) NOT NULL,
    phone      VARCHAR(12) NOT NULL,
    age        INT NOT NULL,
    job        VARCHAR(20) NOT NULL,
    shift      VARCHAR(20) NOT NULL,
    salary     INT NOT NULL,
    theater_id INT NOT NULL,
    FOREIGN KEY (theater_id) REFERENCES Theaters(theater_id)
);

CREATE TABLE IF NOT EXISTS Showtime (
    showtime_id SERIAL PRIMARY KEY,
    film_id     INT NOT NULL,
    theater_id  INT NOT NULL,
    hall_number INT NOT NULL,
    date        DATE NOT NULL,
    start_time  TIME NOT NULL,
    status      VARCHAR(10) CHECK (status IN ('Scheduled', 'Cancelled', 'Postponed')),
    FOREIGN KEY (film_id)    REFERENCES Films(film_id),
    FOREIGN KEY (theater_id) REFERENCES Theaters(theater_id)
);

CREATE TABLE IF NOT EXISTS Screenings (
    screening_id   SERIAL PRIMARY KEY,
    film_id        INT NOT NULL,
    theater_id     INT NOT NULL,
    screening_date DATE NOT NULL,
    start_time     TIME NOT NULL,
    end_time       TIME NOT NULL,
    hall_number    INT NOT NULL,
    FOREIGN KEY (film_id)    REFERENCES Films(film_id),
    FOREIGN KEY (theater_id) REFERENCES Theaters(theater_id)
);

CREATE TABLE IF NOT EXISTS Operations (
    operation_id   SERIAL PRIMARY KEY,
    operation_type VARCHAR(10) CHECK (operation_type IN ('Purchased', 'Refund', 'Failure'))
);

CREATE TABLE IF NOT EXISTS Customers (
    customer_id  SERIAL PRIMARY KEY,
    name         VARCHAR(20) NOT NULL,
    age          INT NOT NULL,
    phone_number VARCHAR(12) NOT NULL,
    credit_card  VARCHAR(12)
);

CREATE TABLE IF NOT EXISTS Seats (
    seat_id      SERIAL PRIMARY KEY,
    hall_row     INT NOT NULL,
    number       INT NOT NULL,
    type_of_seat VARCHAR(22) CHECK (type_of_seat IN ('Normal', 'Comfort', 'Referential_treatment'))
);

CREATE TABLE IF NOT EXISTS Pricing (
    pricing_id             SERIAL PRIMARY KEY,
    type_of_seat           VARCHAR(10),
    adult_price            DECIMAL(4,3) NOT NULL,
    child_price            DECIMAL(4,3) NOT NULL,
    preferential_treatment DECIMAL(4,3) NOT NULL,
    theater_id             INT NOT NULL,
    FOREIGN KEY (theater_id) REFERENCES Theaters(theater_id)
);

CREATE TABLE IF NOT EXISTS Reservations (
    reservation_id SERIAL PRIMARY KEY,
    customer_id    INT NOT NULL,
    seats          INT NOT NULL,
    time           TIME NOT NULL,
    hall           INT NOT NULL,
    status         VARCHAR(10) CHECK (status IN ('Pending', 'Confirmed', 'Cancelled')),
    operation_id   INT,
    FOREIGN KEY (customer_id)  REFERENCES Customers(customer_id),
    FOREIGN KEY (operation_id) REFERENCES Operations(operation_id)
);

CREATE TABLE IF NOT EXISTS Reservation_Seats (
    reservation_id INT NOT NULL,
    seat_id        INT NOT NULL,
    PRIMARY KEY (reservation_id, seat_id),
    FOREIGN KEY (reservation_id) REFERENCES Reservations(reservation_id),
    FOREIGN KEY (seat_id)        REFERENCES Seats(seat_id)
);
